# Mo's Auto Trading — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env

MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/mo_auto_trading
SESSION_SECRET=replace-with-a-long-random-string
DVLA_API_KEY=your-dvla-api-key
PORT=10000

# AI microservice base URL (local dev)
AI_SERVICE_URL=http://localhost:8000
